    "def equation(t, L):\n",
    "\n",
    "# equation représente la dérivée dL/dt.\n",
    "\n",
    "#Paramètres\n",
    "    \n",
    "    #t : float\n",
    "    #    Temps courant.\n",
    "    #   Fourni automatiquement par solve_ivp.\n",
    "\n",
    "    #L : float ou ndarray\n",
    "    #    Valeur courante de la variable L à un instant t\n",
    "\n",
    "# Retour\n",
    "    \n",
    "    #float ou ndarray\n",
    "    #    Valeur de la dérivée dL/dt\n",
    "\n",
    "    return 3 * L"
   ]
