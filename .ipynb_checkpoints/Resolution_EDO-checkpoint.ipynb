  {
   "cell_type": "markdown",
   "id": "ab11a128-c5e9-41b2-8c97-3354c8c35662",
   "metadata": {},
   "source": [
    "Importation: "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 9,
   "id": "9f728636-79d5-49fc-aa9c-bc23dbef917c",
   "metadata": {},
   "outputs": [],
   "source": [
    "import sympy as sp\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "4a214203-ead8-428c-a3d1-0791b7a8dcf1",
   "metadata": {},
   "source": [
    "### 2.b- Définition de la variable indépendante"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
   "id": "db2dfd93-706e-430f-9023-a098af0754e7",
   "metadata": {},
   "outputs": [],
   "source": [
    "t = sp.Symbol('t')\n",
    "# Symbol représente une variable mathématique symbolique.\n",
    "# Ici t joue le rôle du temps."
   ]
  },
  {
   "cell_type": "markdown",
   "id": "c14ebad2-3d51-42f1-bb1b-8ce94fda329b",
   "metadata": {},
   "source": [
    "### 2.c- Définition de la fonction inconnue"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 11,
   "id": "435e4548-a1f7-4731-b343-54d1356fc214",
   "metadata": {},
   "outputs": [],
   "source": [
    "L = sp.Function('L')\n",
    "# Function crée une fonction symbolique.\n",
    "# L(t) représente l'inconnue de l'équation."
   ]
  },
  {
   "cell_type": "markdown",
   "id": "1df793e9-1584-4e3a-8e32-ddfe29710560",
   "metadata": {},
   "source": [
    "### 2.d- Définition de l'EDO"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 12,
   "id": "85ab70f9-4ab1-4f94-9ece-59e195f42dd7",
   "metadata": {},
   "outputs": [],
   "source": [
    "equation = sp.Eq(\n",
    "    sp.Derivative(L(t), t),\n",
    "    3 * L(t))\n",
    "\n",
    "# Eq construit une égalité mathématique sp.Eq(membre gauche, membre droit)\n",
    "#\n",
    "# Derivative(L(t), t) représente dL/dt.\n",
    "#\n",
    "# Et ici :\n",
    "# dL/dt = 3L \n",
    "# Valeur de la dérivée dL/dt à modifier en fonction de l'EDO\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "5470ad44-2761-419b-9fda-8de18d9e97d4",
   "metadata": {},
   "source": [
    "### 2.e- Résolution analytique d'une EDO avec condition initiale"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 13,
   "id": "5902a26b-2a77-4145-bf7c-689a2c68ea38",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Solution avec condition initiale :\n",
      "        3⋅t\n",
      "L(t) = ℯ   \n"
     ]
    }
   ],
   "source": [
    "solution_ci = sp.dsolve(\n",
    "    equation,\n",
    "    ics={L(0): 1})\n",
    "\n",
    "print(\"Solution avec condition initiale :\")\n",
    "sp.pprint(solution_ci)\n",
    "\n",
    "# dsolve :\n",
    "# Fonction principale de SymPy pour résoudre les EDO.\n",
    "#\n",
    "# Elle prend une équation différentielle en argument (equation)\n",
    "# et une condition initiale: ics (dictionnaire)\n",
    "# et retourne la solution analytique.\n",
    "\n",
    "#forme de solution_ci: Eq(L(t), expression littérale)\n",
    "#\n",
    "#sp.pprint : comme print, affiche le résultat\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "cc15b624-9017-4a3b-b9ac-7f3388e61955",
   "metadata": {},
   "source": [
    "### 2.f- Transformation de la solution pour le tracé"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 14,
   "id": "eb5567b3-67d5-4815-a4ea-a4915884158c",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Extraction du membre de droite\n",
    "expression = solution_ci.rhs\n",
    "\n",
    "#.rhs : membre de droite de l'équation, extrait depuis l'objet solution_ci\n",
    "#en opposition avec .lhs, membre de gauche de l'équation\n",
    "\n",
    "#conversion en fonction numérique\n",
    "\n",
    "fonction_numerique = sp.lambdify(\n",
    "    t,\n",
    "    expression,\n",
    "    modules=[\"numpy\"])\n",
    "\n",
    "#sp.lamdify : transforme une expression symbolique SymPy en fonction \n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "816cca7a-bda2-429b-8f26-ca7787c153b0",
   "metadata": {},
   "source": [
    "### 2- g. Affichage résultats"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 15,
   "id": "a626ea03-54d4-4b8b-82e9-d35f1291c98a",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 640x480 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "#création de 200 points entre t0 et tf par np.linspace\n",
    "\n",
    "t_values = np.linspace(0, 2, 200)\n",
    "\n",
    "# calcul de L(t) pour toutes les valeurs de t stockées dans t_values\n",
    "# par la fonction créée en 2.f- (fonction_numerique)\n",
    "\n",
    "L_values = fonction_numerique(t_values)\n",
    "\n",
    "#tracé du graphique issu de la solution analytique\n",
    "\n",
    "plt.plot(\n",
    "    t_values,\n",
    "    L_values,\n",
    "    label=\"L(t)=2e^(3t)\")\n",
    "\n",
    "# t_values :  axe des x\n",
    "#L_values: axe des y \n",
    "#label: légende associée au graphique\n",
    "\n",
    "plt.xlabel(\"t\")\n",
    "\n",
    "# nom de l'axe horizontal\n",
    "\n",
    "plt.ylabel(\"L(t)\")\n",
    "\n",
    "# nom de l'axe vertical\n",
    "\n",
    "plt.title(\"Solution de dL/dt = 3L\")\n",
    "\n",
    "# titre du graphique\n",
    "\n",
    "plt.legend()\n",
    "\n",
    "# affiche les légendes\n",
    "\n",
    "plt.show()\n",
    "\n",
    "# affiche la figure à l'écran"
